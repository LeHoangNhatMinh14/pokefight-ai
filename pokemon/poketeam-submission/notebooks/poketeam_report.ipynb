    "  <text x=\"100\" y=\"139\" class=\"sub-text\">... (22 features total)</text>\n",
    "  <rect x=\"220\" y=\"80\" width=\"100\" height=\"40\" class=\"box\"/>\n",
    "  <text x=\"270\" y=\"98\" class=\"title-text\">Start</text>\n",
    "  <text x=\"270\" y=\"112\" class=\"running\">0.00</text>\n",
    "  <g transform=\"translate(0,170)\">\n",
    "    <text x=\"20\" y=\"0\" class=\"heading\">200 trees, each tugs the running total</text>\n",
    "    <rect x=\"20\" y=\"20\" width=\"140\" height=\"80\" class=\"tree\"/>\n",
    "    <text x=\"90\" y=\"38\" class=\"title-text\">Tree 1</text>\n",
    "    <text x=\"90\" y=\"54\" class=\"tree-q\">teammate_logweight</text>\n",
    "    <text x=\"90\" y=\"66\" class=\"tree-q\">&gt; 1.5? yes</text>\n",
    "    <text x=\"90\" y=\"80\" class=\"tree-q\">type_count &gt; 5? yes</text>\n",
    "    <text x=\"90\" y=\"95\" class=\"adj-pos\">+0.20</text>\n",
    "    <rect x=\"180\" y=\"20\" width=\"140\" height=\"80\" class=\"tree\"/>\n",
    "    <text x=\"250\" y=\"38\" class=\"title-text\">Tree 2</text>\n",
    "    <text x=\"250\" y=\"54\" class=\"tree-q\">role_unique_count</text>\n",
    "    <text x=\"250\" y=\"66\" class=\"tree-q\">&gt; 3? yes</text>\n",
    "    <text x=\"250\" y=\"80\" class=\"tree-q\">avg_usage &lt; 0.5? yes</text>\n",
    "    <text x=\"250\" y=\"95\" class=\"adj-pos\">+0.05</text>\n",
    "    <rect x=\"340\" y=\"20\" width=\"140\" height=\"80\" class=\"tree\"/>\n",
    "    <text x=\"410\" y=\"38\" class=\"title-text\">Tree 3</text>\n",
    "    <text x=\"410\" y=\"54\" class=\"tree-q\">embedding_cos_min</text>\n",
    "    <text x=\"410\" y=\"66\" class=\"tree-q\">&lt; 0.1? yes</text>\n",
    "    <text x=\"410\" y=\"80\" class=\"tree-q\">legendary_count &gt; 1? no</text>\n",
    "    <text x=\"410\" y=\"95\" class=\"adj-neg\">-0.10</text>\n",
    "    <rect x=\"500\" y=\"20\" width=\"140\" height=\"80\" class=\"tree\"/>\n",
    "    <text x=\"570\" y=\"38\" class=\"title-text\">Tree 4</text>\n",
    "    <text x=\"570\" y=\"54\" class=\"tree-q\">weakness_concentration</text>\n",
    "    <text x=\"570\" y=\"66\" class=\"tree-q\">&lt;= 2? yes</text>\n",
    "    <text x=\"570\" y=\"80\" class=\"tree-q\">stat_speed_mean ...</text>\n",
    "    <text x=\"570\" y=\"95\" class=\"adj-pos\">+0.30</text>\n",
    "    <rect x=\"660\" y=\"20\" width=\"80\" height=\"80\" class=\"tree\" style=\"stroke-dasharray: 4 4;\"/>\n",
    "    <text x=\"700\" y=\"60\" class=\"title-text\">. . .</text>\n",
    "    <text x=\"700\" y=\"80\" class=\"sub-text\">196 more</text>\n",
    "    <rect x=\"760\" y=\"20\" width=\"100\" height=\"80\" class=\"tree\"/>\n",
    "    <text x=\"810\" y=\"38\" class=\"title-text\">Tree 200</text>\n",
    "    <text x=\"810\" y=\"60\" class=\"tree-q\">(small final</text>\n",
    "    <text x=\"810\" y=\"72\" class=\"tree-q\">adjustment)</text>\n",
    "    <text x=\"810\" y=\"95\" class=\"adj-pos\">+0.05</text>\n",
    "  </g>\n",
    "  <g transform=\"translate(0,295)\">\n",
    "    <text x=\"90\" y=\"0\" class=\"running\">0.20</text>\n",
    "    <text x=\"250\" y=\"0\" class=\"running\">0.25</text>\n",
    "    <text x=\"410\" y=\"0\" class=\"running\">0.15</text>\n",
    "    <text x=\"570\" y=\"0\" class=\"running\">0.45</text>\n",
    "    <text x=\"700\" y=\"0\" class=\"sub-text\">running total</text>\n",
    "    <text x=\"810\" y=\"0\" class=\"running\">+2.10</text>\n",
    "    <text x=\"440\" y=\"22\" class=\"label-text\" style=\"font-style: italic;\">running total grows with each tree's adjustment</text>\n",
    "  </g>\n",
    "  <path d=\"M 180 100 L 220 100\" class=\"flow\" marker-end=\"url(#arrA2)\"/>\n",
    "  <path d=\"M 320 100 L 340 100\" class=\"flow\" stroke-dasharray=\"2 2\"/>\n",
    "  <path d=\"M 480 100 L 500 100\" class=\"flow\" stroke-dasharray=\"2 2\"/>\n",
    "  <path d=\"M 640 100 L 660 100\" class=\"flow\" stroke-dasharray=\"2 2\"/>\n",
    "  <path d=\"M 740 100 L 760 100\" class=\"flow\" stroke-dasharray=\"2 2\"/>\n",
    "  <path d=\"M 700 350 L 700 380\" class=\"flow\" marker-end=\"url(#arrA2)\"/>\n",
    "  <g transform=\"translate(0,360)\">\n",
    "    <rect x=\"20\" y=\"20\" width=\"240\" height=\"60\" class=\"sum\"/>\n",
    "    <text x=\"140\" y=\"44\" class=\"title-text\">Final raw sum</text>\n",
    "    <text x=\"140\" y=\"62\" class=\"running\" style=\"font-size: 16px;\">+2.10</text>\n",
    "    <text x=\"140\" y=\"75\" class=\"sub-text\">(any positive or negative number)</text>\n",
    "    <rect x=\"320\" y=\"20\" width=\"240\" height=\"60\" class=\"sigmoid\"/>\n",
    "    <text x=\"440\" y=\"40\" class=\"title-text\">Sigmoid function</text>\n",
    "    <text x=\"440\" y=\"56\" class=\"sub-text\">squishes the raw sum into 0..1</text>\n",
    "    <text x=\"440\" y=\"72\" class=\"sub-text\">sigmoid(2.10) = 0.89</text>\n",
    "    <rect x=\"620\" y=\"20\" width=\"240\" height=\"60\" class=\"out\"/>\n",
    "    <text x=\"740\" y=\"44\" class=\"title-text\">Viability score</text>\n",
    "    <text x=\"740\" y=\"64\" class=\"running\" style=\"font-size: 20px; fill: #16a34a;\">0.89</text>\n",
    "  </g>\n",
    "  <path d=\"M 260 390 L 320 390\" class=\"flow\" marker-end=\"url(#arrA2)\"/>\n",
    "  <path d=\"M 560 390 L 620 390\" class=\"flow\" marker-end=\"url(#arrA2)\"/>\n",
    "  <text x=\"440\" y=\"525\" class=\"sub-text\" style=\"font-style: italic;\">if the trees summed to -1.8 instead, sigmoid would give 0.14 - same model, different team, different score</text>\n",
    "</svg>\"\"\"\n",
    "\n",
    "display(SVG(SVG_TREE_SCORING))"
