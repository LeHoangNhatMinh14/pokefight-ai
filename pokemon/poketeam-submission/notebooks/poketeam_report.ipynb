    "    .flow { stroke: #6b7280; stroke-width: 1.4; fill: none; }\n",
    "    .tree-q { font: 500 9.5px system-ui, sans-serif; fill: #1c1917; text-anchor: middle; }\n",
    "  </style>\n",
    "  <text x=\"20\" y=\"28\" class=\"heading\">SCORING A TEAM - 200 small trees, each tugging the running total</text>\n",
    "  <rect x=\"20\" y=\"60\" width=\"160\" height=\"80\" class=\"input\"/>\n",
